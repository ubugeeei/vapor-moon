{
  "name": "ubugeeei/vapor_moon",
  "version": "0.1.0",
  "deps": {
    "mizchi/js": "0.10.14",
    "mizchi/luna": "0.18.3",
    "moonbitlang/parser": "0.1.17",
    "moonbitlang/x": "0.4.40",
    "mizchi/ripple": "0.1.3"
  },
  "readme": "README.md",
  "repository": "https://github.com/ubugeeei/vapor-moon",
  "license": "MIT",
  "exclude": [
    ".github",
    ".githooks",
    "actrun.toml",
    "bin",
    "e2e",
    "editors",
    "examples",
    "scripts",
    "testdata",
    "README.mbt.md",
    "src/compiler/script_setup_test",
    "src/compiler/snapshot",
    "src/compiler/test_support",
    "src/**/*_test.mbt"
  ],
  "keywords": [
    "moonbit",
    "sfc",
    "compiler",
    "vue",
    "island"
  ],
  "description": "Vapor Moon is a MoonBit-first Single File Component compiler and tooling layer built on top of luna.mbt.",
  "preferred-target": "native"
}
